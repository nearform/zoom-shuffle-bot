{
  "name": "zoom-shuffle-bot",
  "version": "3.0.20",
  "description": "",
  "main": "chatbot.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-test-module-mocks --test --env-file=.env.test --test-skip-pattern=test/integration",
    "test:unit": "node --experimental-test-module-mocks --test --env-file=.env.test helpers/crypto.test.js plugins/helpers/getTokenExpiresOn.test.js plugins/helpers/isTokenExpired.test.js plugins/validateOptions.test.js plugins/verifyRequest.test.js routes/bot.test.js test/integration/healthcheck.test.js",
    "test:integration": "firebase emulators:exec --only firestore --project shuffle-zoom-bot \"node --test --env-file=.env.test --test-name-pattern=test/integration\"",
    "start": "node chatbot.js",
    "dev": "nodemon chatbot.js",
    "lint": "eslint . --ext .js,.cjs",
    "lint:fix": "eslint --fix . --ext .js,.cjs",
    "db:up": "firebase emulators:start --project shuffle-zoom-bot"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/firestore": "^8.5.0",
    "desm": "^1.3.1",
    "dotenv": "^17.4.2",
    "env-schema": "^7.0.0",
    "fast-json-stringify": "^6.3.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fluent-json-schema": "^6.0.0",
    "http-errors": "^2.0.1",
    "node-fetch": "^3.3.2",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "firebase-tools": "^14.27.0",
    "firestore-jest-mock": "^0.26.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.2"
  }
}
